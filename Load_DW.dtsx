                  dataType="System.String"
                  description="The SQL command to be executed."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT
    transaction_id,
    MAX(transaction_timestamp) AS transaction_timestamp,
    MAX(merchant_category) AS merchant_category,
    MAX(sender_bank) AS sender_bank,
    MAX(receiver_bank) AS receiver_bank,
    MAX(transaction_type) AS transaction_type,
    MAX(device_type) AS device_type,
    MAX(network_type) AS network_type,
    MAX(sender_age_group) AS sender_age_group,
    MAX(receiver_age_group) AS receiver_age_group,
    MAX(sender_state) AS sender_state,
    MAX(amount_inr) AS amount_inr,
    MAX(fraud_flag) AS fraud_flag,
    MAX(transaction_status) AS transaction_status
FROM UPI_Staging.dbo.stg_UPI_Transactions
GROUP BY transaction_id;</property>
