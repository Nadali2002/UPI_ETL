                  description="The SQL command to be executed."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT DISTINCT
    CONVERT(INT, FORMAT(CONVERT(DATETIME, transaction_timestamp), 'yyyyMMdd')) AS date_key,
    CAST(CONVERT(DATETIME, transaction_timestamp) AS DATE) AS full_date,
    DAY(CONVERT(DATETIME, transaction_timestamp)) AS day,
    MONTH(CONVERT(DATETIME, transaction_timestamp)) AS month,
    YEAR(CONVERT(DATETIME, transaction_timestamp)) AS year,
    DATEPART(QUARTER, CONVERT(DATETIME, transaction_timestamp)) AS quarter,
    day_of_week,
    is_weekend
FROM UPI_Staging.dbo.stg_UPI_Transactions;</property>
