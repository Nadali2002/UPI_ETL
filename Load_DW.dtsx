                  name="OpenRowsetVariable"></property>
                <property
                  dataType="System.String"
                  description="The SQL command to be executed."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT DISTINCT
    s.bank_name,
    b.bank_group,
    b.bank_type
FROM
(
    SELECT sender_bank AS bank_name
    FROM dbo.stg_UPI_Transactions

    UNION

    SELECT receiver_bank AS bank_name
    FROM dbo.stg_UPI_Transactions
) s
LEFT JOIN dbo.stg_BankMaster b
    ON s.bank_name = b.bank_name;</property>
