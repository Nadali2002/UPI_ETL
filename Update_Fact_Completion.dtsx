                  description="The SQL command to be executed."
                  expressionType="Notify"
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">UPDATE dbo.FactUPITransactions
SET
    accm_txn_complete_time = ?,
    txn_process_time_hours = DATEDIFF(MINUTE, accm_txn_create_time, ?) / 60.0
WHERE transaction_id = ?;</property>
